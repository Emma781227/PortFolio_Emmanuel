---
import Section from './ui/Section.astro';
import Card from './ui/Card.astro';
import Button from './ui/Button.astro';

const experiences = [
  {
    title: 'Mastère 2 Architecte Web',
    company: 'Digital School of Paris - Institut F2I',
    period: 'BAC+5 : 2025 - Présent',
    year: 2026,
    description: "Formation d’expertise en alternance orientée architecture web, développement full-stack et pilotage de projets digitaux. Acquisition de compétences en conception et déploiement d’applications complexes, en gestion d’équipes techniques et en stratégie de transformation digitale",
    technologies: [
      "Digitalisation",
      "Full-Stack",
      "Gestion de projet",
      "DevOps",
      "Leadership",
      "UX/UI Design"
    ],
    type: 'education'
  },
  {
    title: 'Master 1 en Concultant Développeur Fullstack',
    company: 'Digital School of Paris - Institut F2I',
    period: '2024 - 2025',
    year: 2023.5,
    description: "Développement de sites web et d’applications responsive, intégration et personnalisation de thèmes WordPress, optimisation du référencement naturel et création de designs modernes, ergonomiques et adaptés aux besoins des utilisateurs.",
    technologies: [
      "Full-Stack",
      "Base de données",
      "Refonte",
      "Maintenance",
      "Mise en production",
      "VS Code Extension",
    ],
    type: 'education'
  },
  {
    title: 'Développeur Web ',
    company: 'Royalty Company',
    period: '2024 - 2025',
    year: 2023.2,
    description: "Pendant ce stage, j’ai contribué au développement et à l’optimisation de sites e-commerce sous WordPress et Shopify. Mes missions comprenaient la personnalisation de thèmes, l’intégration de pages produits, le développement de fonctionnalités adaptées aux besoins clients, ainsi que l’optimisation SEO et des performances techniques. J’ai aussi participé à la configuration d’emails professionnels, à la migration vers des domaines personnalisés et à l’analyse des performances avec Google Analytics.",
    technologies: [
      "Full-Stack",
      "WordPress",
      "Integration Produit",
      "Google Analytics",
      "CMS",
      "SEO",
    ],
    type: 'work'
  },
  {
    title: 'Développeur Web - Stage',
    company: 'GHL plugins',
    period: '2023',
    year: 2023,
    description: "Au cours de mon stage en développement web chez GHL Plugins, entreprise spécialisée dans les solutions digitales au Cameroun, j’ai contribué à la création et à l’amélioration de sites et applications web. Cette expérience m’a permis de consolider mes compétences techniques, de mieux comprendre les besoins clients et de participer à la mise en place de solutions web fonctionnelles, modernes et adaptées aux usages. J’y ai également développé mon sens de l’organisation, ma capacité d’adaptation et mon autonomie dans un cadre professionnel.",
    technologies: [
      "Développement Web",
      "Gestion de contenu",
      "Newsletter",
      "Base de données",
      "Authentification",
    ],
    type: 'work'
  },
  {
    title: 'Bac +2 Développer Web',
    company: 'ICT University',
    period: '2023',
    year: 2022,
    description: "Dans le cadre de mon Bac+2 en développement web à ICT University, au Cameroun, j’ai été formé à la création de sites web responsive, à la conception d’interfaces web et mobiles avec Figma, ainsi qu’au développement d’applications et de sites en Java. Cette formation m’a permis de construire une base technique solide en développement et en design d’interface, tout en renforçant ma capacité à concevoir des solutions adaptées aux besoins des utilisateurs.",
    technologies: [
      "Développement Web",
      "Base de données",
      "Scripting",
      "Design "
    ],
    type: 'education'
  },
  
].sort((a, b) => b.year - a.year);
---

<Section 
  id="experience" 
  title="Parcours"
  subtitle="Mon parcours académique et professionnel"
>
  <div class="relative">
    <!-- Timeline verticale -->
    <div class="hidden md:block absolute left-1/2 transform -translate-x-1/2 h-full w-0.5 bg-gradient-to-b from-primary-500 to-primary-600"></div>

    <!-- Expériences -->
    <div class="space-y-12">
      {experiences.map((exp, index) => (
        <div 
          class={`reveal flex flex-col md:flex-row items-center gap-8 ${
            index % 2 === 0 ? 'md:flex-row-reverse' : ''
          }`}
        >
          <!-- Carte d'expérience -->
          <div class="flex-1 w-full">
            <Card>
              <!-- Contenu -->
              <div>
                <div class="flex items-start justify-between mb-3">
                  <div>
                    <div class="mb-2">
                      <span class={`inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold ${
                        exp.type === 'work'
                          ? 'bg-gradient-to-r from-primary-500 to-primary-600 text-white'
                          : 'bg-gradient-to-r from-dark-700 to-dark-600 text-primary-400'
                      }`}>
                        {exp.type === 'work' ? '💼 Expérience' : '🎓 Formation'}
                      </span>
                    </div>
                    <h3 class="text-xl font-bold text-dark-100 mb-1">{exp.title}</h3>
                    <p class="text-primary-400 font-medium">{exp.company}</p>
                  </div>
                  <span class="text-sm text-dark-400 whitespace-nowrap ml-4">{exp.period}</span>
                </div>

                <p class="text-dark-300 mb-4 leading-relaxed">
                  {exp.description}
                </p>

                <!-- Technologies -->
                <div class="flex flex-wrap gap-2">
                  {exp.technologies.map((tech) => (
                    <span class="px-3 py-1 rounded-lg bg-dark-800/50 text-primary-400 text-sm border border-dark-700">
                      {tech}
                    </span>
                  ))}
                </div>

                {exp.title.includes('Licence Professionnelle') && (
                  <div class="mt-4">
                    <Button href="https://www.canva.com/design/DAGQdmJ6wv4/7Lu6Ywv06X51AH2pgMDwWg/view?utm_content=DAGQdmJ6wv4&utm_campaign=designshare&utm_medium=link2&utm_source=uniquelinks&utlId=haa0fe0e684" variant="outline" size="sm">
                      Voir ma soutenance
                    </Button>
                  </div>
                )}
              </div>
            </Card>
          </div>

          <!-- Point sur la timeline (desktop uniquement) -->
          <div class="hidden md:block relative flex-shrink-0">
            <div class="w-4 h-4 rounded-full bg-primary-500 border-4 border-dark-900 shadow-lg shadow-primary-500/50"></div>
            <div class="absolute inset-0 w-4 h-4 rounded-full bg-primary-500 animate-ping opacity-75"></div>
          </div>

          <!-- Espace pour l'autre côté -->
          <div class="hidden md:block flex-1"></div>
        </div>
      ))}
    </div>
  </div>

  <!-- CTA pour télécharger le CV -->
  <div class="text-center mt-16 reveal">
    <a 
      href="CV_Engongomo.pdf" 
      download
      class="inline-flex items-center gap-2 px-8 py-4 rounded-2xl bg-gradient-to-r from-primary-500 to-primary-600 text-white font-semibold hover:shadow-xl hover:shadow-primary-500/30 transition-all duration-300 hover:scale-105"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
      </svg>
      Télécharger mon CV
    </a>
  </div>
</Section>