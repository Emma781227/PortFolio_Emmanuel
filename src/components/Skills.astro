---
import Section from "./ui/Section.astro";
import Card from "./ui/Card.astro";

const skillCategories = [
    {
        title: "Frontend",
        icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
    </svg>`,
        focus: "Conception d'interfaces robustes, performantes et maintenables.",
        skills: ["HTML5", "CSS3", "JavaScript", "TypeScript", "Angular", "Next.js", "Vue.js", "Astro", "ExtJS"],
    },
    {
        title: "Backend & API",
        icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path>
    </svg>`,
        focus: "Développement de services web sécurisés et d'API orientées métier.",
        skills: ["PHP", "Symfony", "Node.js", "NestJS", "Express", "API REST", "Architecture MVC"],
    },
    {
        title: "Base de données & Mobile",
        icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path>
    </svg>`,
        focus: "Modélisation fiable des données et développement orienté usage mobile.",
        skills: ["SQL", "MySQL", "PostgreSQL", "Prisma", "NeonDB", "Firebase", "Supabase", "Flutter", "Dart"],
    },
    {
        title: "DevOps & CI/CD",
        icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
    </svg>`,
        focus: "Automatisation des workflows de build, test et déploiement.",
        skills: ["Git", "GitHub", "GitHub Actions", "CircleCI", "Docker", "Netlify", "Vercel"],
    },
    {
        title: "Qualité & Performance",
        icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
    </svg>`,
        focus: "Approche orientée fiabilité, monitoring et amélioration continue.",
        skills: ["Tests unitaires", "Sentry", "SEO", "Optimisation des performances"],
    },
    {
        title: "Gestion de projet",
        icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
    </svg>`,
        focus: "Pilotage clair des priorités, planning et coordination d'équipe.",
        skills: ["Méthodes Agiles", "Scrum", "Jira", "Trello", "GitHub Projects", "Diagrammes de Gantt"],
    },
];

const otherSkills = [
    "Responsive Design",
    "Accessibilité Web",
    "UX/UI Design",
    "Markdown",
    "Sécurité Web",
    "Architecture Web",
    "Modélisation UML",
    "Maintenance & Migration",
    "Veille technologique",
    "WAMP / PhpMyAdmin",
    "Render / Railway",
    "SVN",
    "Figma",
];
---

<Section
    id="skills"
    title="Compétences"
    subtitle="Expertises techniques et pratiques professionnelles"
>
    <!-- Domaines de compétences -->
    <div class="grid md:grid-cols-2 gap-8 mb-16">
        {
            skillCategories.map((category, catIndex) => (
                <div
                    class="reveal"
                    style={`animation-delay: ${catIndex * 0.1}s`}
                >
                    <Card className="border border-primary-500/20">
                        <div class="flex items-center gap-4 mb-6">
                            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center text-white">
                                <Fragment set:html={category.icon} />
                            </div>
                            <h3 class="text-2xl font-bold text-dark-100">
                                {category.title}
                            </h3>
                        </div>

                        <p class="text-dark-300 mb-5 leading-relaxed">
                            {category.focus}
                        </p>

                        <div class="flex flex-wrap gap-2">
                            {category.skills.map((skill) => (
                                <span class="px-3 py-2 rounded-lg border border-primary-500/30 bg-primary-500/10 text-dark-100 text-sm hover:bg-primary-500/20 hover:border-primary-400/50 transition-colors duration-300">
                                    {skill}
                                </span>
                            ))}
                        </div>
                    </Card>
                </div>
            ))
        }
    </div>

    <!-- Compétences complémentaires -->
    <div class="reveal">
        <h3 class="text-2xl font-bold text-center mb-8 text-dark-100">
            Outils et pratiques transverses
        </h3>
        <div class="flex flex-wrap justify-center gap-3">
            {
                otherSkills.map((skill, index) => (
                    <span
                        class="skill-tag px-5 py-3 rounded-xl text-dark-100 bg-primary-500/10 border border-primary-500/30 hover:bg-primary-500/20 hover:border-primary-400/50 hover:text-primary-300 hover:scale-105 transition-all duration-300 cursor-default"
                        style={`animation-delay: ${index * 0.05}s`}
                    >
                        {skill}
                    </span>
                ))
            }
        </div>
    </div>
</Section>
